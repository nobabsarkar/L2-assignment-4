
model User {
    id String @id @default(uuid())
    name String
    email String @unique
    password String 
    role Role 
    status UserStatus @default(ACTIVE)

    profile Profile?
    properties Property[]
    
    rentalRequests RentalRequest[]

    reviews Review[]

    payments Payment[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
    
}